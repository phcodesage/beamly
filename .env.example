# Beamly Environment Template (.env.example)
SECRET_KEY=your-secret-key-here
FLASK_DEBUG=False
HOST=0.0.0.0
PORT=5001
BACKEND_URL=https://beamly-1.onrender.com

# Cloudflare Calls TURN Server Credentials
CLOUDFLARE_TURN_KEY_ID=your-cloudflare-turn-key-id
CLOUDFLARE_TURN_API_TOKEN=your-cloudflare-turn-api-token

# Room Lifecycle & Transfer Limits
ROOM_EXPIRATION_SECONDS=3600
MAX_FILE_SIZE_MB=10240
